ns\\\"}]}]},\\\"search\\\":{\\\"provider\\\":\\\"local\\\"},\\\"socialLinks\\\":[{\\\"icon\\\":\\\"github\\\",\\\"link\\\":\\\"https://github.com/nklisch/skilltap\\\"}],\\\"footer\\\":{\\\"message\\\":\\\"Released under the MIT License.\\\",\\\"copyright\\\":\\\"By <a href=\\\\\\\"https://nathanklisch.dev\\\\\\\">Nathan Klisch</a> · Also: <a href=\\\\\\\"https://krometrail.dev\\\\\\\">Krometrail</a> · <a href=\\\\\\\"https://godot-theatre.dev\\\\\\\">Theatre</a> · <a href=\\\\\\\"https://ffmpegkit.dev\\\\\\\">ffmpeg-kit</a>\\\"},\\\"editLink\\\":{\\\"pattern\\\":\\\"https://github.com/nklisch/skilltap/edit/main/website/:path\\\",\\\"text\\\":\\\"Edit this page on GitHub\\\"}},\\\"locales\\\":{},\\\"scrollOffset\\\":134,\\\"cleanUrls\\\":true}\");</script>\n    \n  \n</body></html>",
